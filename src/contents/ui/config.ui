     </property>
    </widget>
   </item>
   <item>
    <layout class="QFormLayout">
        <item row="0" column="0"><widget class="QLabel"><property name="text"><string>on new window:</string></property></widget></item>
        <item row="0" column="1"><widget class="QCheckBox" name="kcfg_autoLayoutOnNewWindow"/></item>

        <item row="1" column="0"><widget class="QLabel"><property name="text"><string>after closing window:</string></property></widget></item>
        <item row="1" column="1"><widget class="QCheckBox" name="kcfg_autoLayoutOnWindowClose"/></item>

