        <item row="3" column="1"><widget class="QCheckBox" name="kcfg_autoLayoutOnWindowRestore"/></item>

        <item row="4" column="0"><widget class="QLabel"><property name="text"><string>on desktop switch:</string></property></widget></item>
        <item row="4" column="1"><widget class="QCheckBox" name="kcfg_autoLayoutOnDesktopChange"/></item>

        <item row="5" column="0"><widget class="QLabel"><property name="text"><string>after switching activity:</string></property></widget></item>
        <item row="5" column="1"><widget class="QCheckBox" name="kcfg_autoLayoutOnActivityChange"><property name="checked"><bool>true</bool></property></widget></item>

